<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WALL TEAM // CYBERPUNK MONITOR</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #050505;
      --card-bg: rgba(10, 15, 20, 0.8);
      --neon-cyan: #00ffff;
      --neon-magenta: #ff00ff;
      --neon-amber: #ffaa00;
      --neon-red: #ff0953;
      --neon-green: #00ff88;
      --line-color: rgba(0, 255, 255, 0.2);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg); color: #fff; font-family: 'JetBrains Mono', monospace;
      overflow-x: hidden; min-height: 100vh; padding: 20px;
      background-image: linear-gradient(rgba(0,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    body::after {
      content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: repeating-linear-gradient(0deg, rgba(0,0,0,0.1) 0px, rgba(0,0,0,0.1) 1px, transparent 1px, transparent 2px);
      pointer-events: none; z-index: 9999;
    }
    .corner { position: fixed; width: 40px; height: 40px; border: 2px solid var(--neon-cyan); pointer-events: none; opacity: 0.5; }
    .corner-tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
    .corner-tr { top: 10px; right: 10px; border-left: none; border-bottom: none; }
    .corner-bl { bottom: 10px; left: 10px; border-right: none; border-top: none; }
    .corner-br { bottom: 10px; right: 10px; border-left: none; border-top: none; }
    .header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 20px; padding: 10px 20px;
      background: var(--card-bg); border: 1px solid var(--line-color); border-radius: 4px; position: relative;
    }
    .header::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--neon-cyan), var(--neon-magenta)); box-shadow: 0 0 10px var(--neon-cyan);
    }
    .title {
      font-family: 'Orbitron', sans-serif; font-size: 1.8rem; font-weight: 900;
      background: linear-gradient(90deg, var(--neon-cyan), var(--neon-magenta));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      text-shadow: 0 0 20px rgba(0,255,255,0.5); letter-spacing: 3px;
    }
    .subtitle { color: var(--neon-cyan); font-size: 0.7rem; opacity: 0.7; letter-spacing: 2px; }
    .system-bar {
      display: flex; gap: 30px; margin-bottom: 20px; padding: 12px 20px;
      background: var(--card-bg); border: 1px solid var(--line-color); border-radius: 4px;
    }
    .sys-item { display: flex; align-items: center; gap: 10px; }
    .sys-label { color: var(--neon-cyan); font-size: 0.75rem; text-transform: uppercase; }
    .sys-value { font-family: 'Orbitron', monospace; font-size: 1rem; color: var(--neon-green); text-shadow: 0 0 5px var(--neon-green); }
    .progress-mini { width: 100px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
    .progress-mini-fill { height: 100%; background: var(--neon-green); transition: width 0.5s; }
    .main-layout { display: grid; grid-template-columns: 1fr 300px; gap: 20px; }
    .agents-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    @media (max-width: 1200px) { .agents-grid { grid-template-columns: repeat(3, 1fr); } .main-layout { grid-template-columns: 1fr; } }
    @media (max-width: 900px) { .agents-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .agents-grid { grid-template-columns: 1fr; } }
    .agent-card {
      background: var(--card-bg); border: 1px solid var(--line-color); border-radius: 4px; padding: 15px;
      position: relative; cursor: pointer; transition: all 0.3s; overflow: hidden;
    }
    .agent-card::before {
      content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 2px; background: var(--neon-cyan);
      animation: scan 3s linear infinite;
    }
    @keyframes scan { 0% { left: -100%; } 100% { left: 100%; } }
    .agent-card:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 10px 30px rgba(0,255,255,0.2); border-color: var(--neon-cyan); }
    .agent-card.wall-g { border-top: 2px solid #ff6b9d; }
    .agent-card.wall-c { border-top: 2px solid var(--neon-cyan); }
    .agent-card.wall-e { border-top: 2px solid var(--neon-green); }
    .agent-card.wall-r { border-top: 2px solid #ffab00; }
    .agent-card.wall-a { border-top: 2px solid #e040fb; }
    .agent-card.wall-b { border-top: 2px solid #ff5252; }
    .agent-card.wall-p { border-top: 2px solid #40c4ff; }
    .agent-card.wall-x { border-top: 2px solid #b388ff; }
    .agent-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .agent-name { font-family: 'Orbitron', sans-serif; font-size: 1rem; font-weight: 700; color: var(--neon-cyan); }
    .agent-status { font-size: 0.7rem; padding: 2px 8px; border-radius: 10px; background: rgba(0,255,255,0.1); color: var(--neon-green); border: 1px solid var(--neon-cyan); }
    .agent-status.idle { color: var(--neon-amber); border-color: var(--neon-amber); background: rgba(255,170,0,0.1); }
    .agent-status.highload { color: var(--neon-red); border-color: var(--neon-red); background: rgba(255,9,83,0.1); animation: blink 1s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.5} }
    .agent-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 0.75rem; color: #aaa; }
    .metric { display: flex; flex-direction: column; }
    .metric-label { color: #666; font-size: 0.65rem; text-transform: uppercase; }
    .metric-value { color: var(--neon-cyan); font-family: 'Orbitron', monospace; }
    .token-bar { grid-column: 1 / -1; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; margin-top: 4px; overflow: hidden; position: relative; }
    .token-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--neon-cyan), var(--neon-magenta)); position: relative; }
    .token-fill::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
      animation: shimmer 2s infinite;
    }
    @keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
    .side-panel { display: flex; flex-direction: column; gap: 20px; }
    .panel-box { background: var(--card-bg); border: 1px solid var(--line-color); border-radius: 4px; padding: 15px; }
    .panel-title { font-family: 'Orbitron', sans-serif; font-size: 0.9rem; color: var(--neon-magenta); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; }
    .topology-svg { width: 100%; height: 200px; background: rgba(0,0,0,0.3); border-radius: 4px; }
    .log-container { max-height: 200px; overflow-y: auto; font-size: 0.7rem; color: #aaa; }
    .log-entry { padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; gap: 8px; }
    .log-time { color: var(--neon-cyan); opacity: 0.7; }
    .log-agent { color: var(--neon-magenta); font-weight: bold; }
    .log-msg { color: #ccc; }
    .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); z-index: 10000; align-items: center; justify-content: center; backdrop-filter: blur(10px); }
    .modal.active { display: flex; }
    .modal-content {
      background: var(--bg); border: 1px solid var(--neon-cyan); border-radius: 8px; width: 90%; max-width: 1200px; max-height: 90vh; overflow: auto; box-shadow: 0 0 50px rgba(0,255,255,0.3); position: relative;
    }
    .modal-close { position: absolute; top: 10px; right: 15px; font-size: 1.5rem; color: var(--neon-cyan); cursor: pointer; z-index: 10; }
    .modal-header { padding: 20px; border-bottom: 1px solid var(--line-color); display: flex; justify-content: space-between; align-items: center; }
    .modal-title { font-family: 'Orbitron', sans-serif; font-size: 1.5rem; color: var(--neon-cyan); }
    .close-btn { background: transparent; border: 1px solid var(--neon-cyan); color: var(--neon-cyan); padding: 8px 16px; cursor: pointer; font-family: 'Orbitron', monospace; transition: all 0.3s; }
    .close-btn:hover { background: var(--neon-cyan); color: #000; }
    .modal-body { padding: 20px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
    @media (max-width: 900px) { .modal-body { grid-template-columns: 1fr; } }
    .chart-box { background: var(--card-bg); border: 1px solid var(--line-color); border-radius: 4px; padding: 15px; height: 300px; position: relative; }
    .chart-title { color: var(--neon-magenta); font-size: 0.85rem; margin-bottom: 10px; text-transform: uppercase; }
    .chart-canvas { width: 100%; height: calc(100% - 30px); background: rgba(0,0,0,0.3); border: 1px solid rgba(0,255,255,0.2); border-radius: 4px; }
    .alert-badge {
      position: fixed; top: 20px; right: 20px; z-index: 9999;
      background: var(--neon-red); color: #fff; padding: 10px 20px; border-radius: 4px;
      font-family: 'Orbitron', monospace; font-size: 0.8rem; animation: alertPulse 1s infinite;
      display: none;
    }
    .alert-badge.active { display: block; }
    @keyframes alertPulse { 0%,100%{box-shadow:0 0 10px var(--neon-red)} 50%{box-shadow:0 0 20px var(--neon-red)} }
  </style>
</head>
<body>
  <div class="corner corner-tl"></div>
  <div class="corner corner-tr"></div>
  <div class="corner corner-bl"></div>
  <div class="corner corner-br"></div>

  <div class="alert-badge" id="alert-badge">⚠️ HIGH LOAD DETECTED</div>

  <div class="header">
    <div>
      <div class="title">✦ WALL TEAM MONITOR ✦</div>
      <div class="subtitle">REAL-TIME CYBERPUNK DASHBOARD V2.0</div>
    </div>
    <div style="text-align: right;">
      <div style="color: var(--neon-cyan); font-size: 0.8rem;" id="clock">00:00:00</div>
      <div style="color: #666; font-size: 0.7rem;" id="date">2026-03-01</div>
    </div>
  </div>

  <div class="system-bar">
    <div class="sys-item">
      <span class="sys-label">CPU</span>
      <span class="sys-value" id="sys-cpu">--</span>
      <div class="progress-mini"><div class="progress-mini-fill" id="cpu-bar" style="width: 0%; background: var(--neon-green);"></div></div>
    </div>
    <div class="sys-item">
      <span class="sys-label">MEM</span>
      <span class="sys-value" id="sys-mem">--</span>
      <div class="progress-mini"><div class="progress-mini-fill" id="mem-bar" style="width: 0%; background: var(--neon-cyan);"></div></div>
    </div>
    <div class="sys-item">
      <span class="sys-label">NET</span>
      <span class="sys-value" id="sys-net">--</span>
    </div>
    <div class="sys-item">
      <span class="sys-label">DISK</span>
      <span class="sys-value" id="sys-disk">--</span>
        <button id="settings-btn" style="background:transparent;border:1px solid var(--neon-cyan);color:var(--neon-cyan);padding:8px 12px;margin-left:15px;cursor:pointer;font-family:Orbitron,monospace;border-radius:4px;" onclick="openSettings()">⚙️</button>
  </div>
  </div>

  <div class="main-layout">
    <div class="agents-grid" id="agents-grid">
      <!-- Agent cards rendered by JS -->
    </div>

    <div class="side-panel">
      <div class="panel-box">
        <div class="panel-title">🌐 NETWORK TOPOLOGY</div>
        <svg class="topology-svg" id="topology"></svg>
    
      <div class="panel-box">
        <div class="panel-title">🔥 24H LOAD HEATMAP</div>
        <canvas class="heatmap-canvas" id="heatmap" width="260" height="120" style="width:100%;height:120px;background:rgba(0,0,0,0.3);border:1px solid rgba(0,255,255,0.2);border-radius:4px;"></canvas>
      </div>
  </div>

      <div class="panel-box">
        <div class="panel-title">📋 ACTIVITY LOG</div>
        <div class="log-container" id="log-container"></div>
      </div>
    </div>
  </div>

  <!-- Agent Detail Modal -->
  <div class="modal" id="agent-modal">
    <div class="modal-content">
      <div class="modal-close" onclick="closeModal()">&times;</div>
      <div class="modal-header">
        <div class="modal-title" id="modal-title">AGENT DETAIL</div>
        <button class="close-btn" onclick="closeModal()">CLOSE</button>
      </div>
      <div class="modal-body">
        <div class="chart-box">
          <div class="chart-title">Token Usage (Recent Sessions)</div>
          <canvas class="chart-canvas" id="chart-token"></canvas>
        </div>
        <div class="chart-box">
          <div class="chart-title">Session Load (24h)</div>
          <canvas class="chart-canvas" id="chart-session"></canvas>
        </div>
        <div class="chart-box">
          <div class="chart-title">Resource Usage (CPU/MEM)</div>
          <canvas class="chart-canvas" id="chart-resource"></canvas>
        </div>
      </div>
    </div>
  </div>

  <script>
    const API_URL = '/api/status';
    const ALERT_THRESHOLD = 80; // token usage % to trigger alert
    
    let agents = {};
    let systemData = {};
    let refreshTimer;;
    let topologyAnimation;
    let alertSound = null;

    // Fetch real data from API
        async function fetchStatus() {
      try {
        const res = await fetch(API_URL);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        
        // Use API agents directly
        const agentsData = data.agents || {};
        const transformed = {};
        for (const [key, agent] of Object.entries(agentsData)) {
          transformed[key] = {
            name: agent.name,
            emoji: agent.emoji || '🤖',
            status: agent.status,
            sessions: agent.sessions,
            tokens: agent.tokens || 0,
            tokenLimit: agent.tokenLimit || 200000,
            tokenPercent: agent.tokenPercent || Math.round((agent.tokens || 0) / (agent.tokenLimit || 200000) * 100),
            cpu: agent.cpu || Math.floor(Math.random() * 30) + 5,
            mem: agent.mem || (Math.random() * 4 + 1).toFixed(1),
            net: agent.net || { down: (Math.random() * 5).toFixed(1), up: (Math.random() * 2).toFixed(1) },
            skills: agent.skills || [],
            tokenHistory: agent.tokenHistory || [],
            hourlyLoad: agent.hourlyLoad || []
          };
        }
        agents = transformed;
        systemData = data.system || {};
        renderAgents();
        updateSystemBar();
        checkAlerts();
        const avgHourly = Object.values(agents).reduce((arr, a) => {
          if (!arr.length) return a.hourlyLoad || [];
          return arr.map((v, i) => v + (a.hourlyLoad?.[i] || 0));
        }, []).map(v => Object.keys(agents).length > 0 ? Math.round(v / Object.keys(agents).length) : 0);
        drawHeatmap(avgHourly);
        addLog('System', 'Data refreshed from API');
      } catch (e) {
        console.error('Fetch failed:', e);
        addLog('ERROR', 'Failed to fetch status: ' + e.message);
      }
    }
sync function fetchStatus() {
      try {
        const res = await fetch(API_URL);
        if (!res.ok) throw new Error(`HTTP ${res.status}
        const avgHourly = Object.values(agents).reduce((arr,a)=>{if(!arr.length)return a.hourlyLoad||[];return arr.map((v,i)=>v+(a.hourlyLoad?.[i]||0));},[]).map(v=>Object.keys(agents).length?Math.round(v/Object.keys(agents).length):0);
        drawHeatmap(avgHourly);`);
        const data = await res.json();
        
        // Transform API data to our format
        const transformed = {};
        for (const [key, agent] of Object.entries(data)) {
          transformed[key] = {
            name: agent.name,
            emoji: agent.emoji || '🤖',
            status: agent.status,
            sessions: agent.sessions,
            tokens: agent.tokens || 0,
            tokenLimit: agent.tokenLimit || 200000,
            tokenPercent: agent.tokenPercent || Math.round((agent.tokens || 0) / (agent.tokenLimit || 200000) * 100),
            cpu: Math.floor(Math.random() * 30) + 5, // Placeholder - would come from system metrics
            mem: (Math.random() * 4 + 1).toFixed(1),
            net: { down: (Math.random() * 5).toFixed(1), up: (Math.random() * 2).toFixed(1) },
            skills: agent.skills || []
          };
        }
        agents = transformed;
        renderAgents();
        updateSystemBar();
        checkAlerts();
        addLog('System', 'Data refreshed from API');
      } catch (e) {
        console.error('Fetch failed:', e);
        addLog('ERROR', 'Failed to fetch status: ' + e.message);
      }
    }

    function renderAgents() {
      const grid = document.getElementById('agents-grid');
      let html = '';
      for (const [key, agent] of Object.entries(agents)) {
        const statusClass = agent.status === 'IDLE' ? 'idle' : agent.tokenPercent > 80 ? 'highload' : '';
        const loadColor = agent.tokenPercent > 80 ? 'var(--neon-red)' : agent.tokenPercent > 50 ? 'var(--neon-amber)' : 'var(--neon-green)';
        html += `
          <div class="agent-card ${key}" onclick="openModal('${key}')">
            <div class="agent-header">
              <span class="agent-name">${agent.emoji} ${agent.name}</span>
              <span class="agent-status ${statusClass}">${agent.status}</span>
            </div>
            <div class="agent-metrics">
              <div class="metric"><span class="metric-label">Sessions</span><span class="metric-value">${agent.sessions}</span></div>
              <div class="metric"><span class="metric-label">CPU</span><span class="metric-value">${agent.cpu}%</span></div>
              <div class="metric"><span class="metric-label">MEM</span><span class="metric-value">${agent.mem} GB</span></div>
              <div class="metric"><span class="metric-label">NET ↓↑</span><span class="metric-value">${agent.net.down} / ${agent.net.up} MB/s</span></div>
            </div>
            <div class="token-bar">
              <div class="token-fill" style="width: ${agent.tokenPercent}%"></div>
            </div>
            <div style="display: flex; justify-content: space-between; margin-top: 6px; font-size: 0.7rem;">
              <span style="color: #666;">TOKENS</span>
              <span style="color: ${loadColor};">${agent.tokens.toLocaleString()} / ${agent.tokenLimit.toLocaleString()} (${agent.tokenPercent}%)</span>
            </div>
          </div>
        `;
      }
      grid.innerHTML = html;
    }

    function updateSystemBar() {
      // Simulated system-wide metrics (would be from real system monitoring)
      const totalCpu = Object.values(agents).reduce((sum, a) => sum + a.cpu, 0);
      const avgCpu = Math.round(totalCpu / Object.keys(agents).length);
      const totalMem = Object.values(agents).reduce((sum, a) => sum + parseFloat(a.mem), 0);
      const avgMem = (totalMem / Object.keys(agents).length).toFixed(1);
      
      document.getElementById('sys-cpu').textContent = avgCpu + '%';
      document.getElementById('cpu-bar').style.width = avgCpu + '%';
      document.getElementById('sys-mem').textContent = avgMem + 'GB';
      document.getElementById('mem-bar').style.width = Math.min(100, (avgMem / 16) * 100) + '%';
      document.getElementById('sys-net').textContent = `↓${(Math.random()*10).toFixed(1)} ↑${(Math.random()*5).toFixed(1)} MB/s`;
      document.getElementById('sys-disk').textContent = '68%'; // placeholder
    }

    function checkAlerts() {
      const highLoadAgents = Object.entries(agents).filter(([k,a]) => a.tokenPercent > ALERT_THRESHOLD);
      const badge = document.getElementById('alert-badge');
      if (highLoadAgents.length > 0) {
        badge.classList.add('active');
        badge.textContent = `⚠️ HIGH LOAD: ${highLoadAgents.map(([k,a]) => a.name).join(', ')}`;
        // Could play sound here
      } else {
        badge.classList.remove('active');
      }
    }

    function addLog(agent, msg) {
      const container = document.getElementById('log-container');
      const now = new Date();
      const time = now.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
      const entry = document.createElement('div');
      entry.className = 'log-entry';
      entry.innerHTML = `<span class="log-time">${time}</span><span class="log-agent">[${agent}]</span><span class="log-msg">${msg}</span>`;
      container.insertBefore(entry, container.firstChild);
      if (container.children.length > 10) container.removeChild(container.lastChild);
    }

    // Topology visualization
    function drawTopology() {
      const svg = document.getElementById('topology');
      const w = svg.offsetWidth || 300;
      const h = 200;
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
      
      const nodes = Object.keys(agents);
      const positions = {};
      const centerX = w/2, centerY = h/2;
      const radius = Math.min(w,h)/3;
      
      // Position nodes in a circle
      nodes.forEach((node, i) => {
        const angle = (i / nodes.length) * Math.PI * 2 - Math.PI/2;
        positions[node] = {
          x: centerX + Math.cos(angle) * radius,
          y: centerY + Math.sin(angle) * radius
        };
      });

      // Build SVG
      let svgContent = '';
      
      // Connection lines (all-to-all for simplicity)
      nodes.forEach((a, i) => {
        nodes.slice(i+1).forEach(b => {
          const pa = positions[a], pb = positions[b];
          svgContent += `<line x1="${pa.x}" y1="${pa.y}" x2="${pb.x}" y2="${pb.y}" stroke="rgba(0,255,255,0.2)" stroke-width="1" />`;
        });
      });

      // Nodes
      nodes.forEach(node => {
        const pos = positions[node];
        const color = getNodeColor(node);
        svgContent += `
          <circle cx="${pos.x}" cy="${pos.y}" r="12" fill="${color}" fill-opacity="0.3" stroke="${color}" stroke-width="2">
            <animate attributeName="r" values="12;14;12" dur="2s" repeatCount="indefinite"/>
          </circle>
          <text x="${pos.x}" y="${pos.y+3}" text-anchor="middle" fill="#fff" font-size="8" font-family="Orbitron">${agents[node].emoji}</text>
        `;
      });

      svg.innerHTML = svgContent;
    }

    function getNodeColor(node) {
      const agent = agents[node];
      if (!agent) return '#00ffff';
      if (agent.status === 'IDLE') return 'var(--neon-amber)';
      if (agent.tokenPercent > 80) return 'var(--neon-red)';
      return 'var(--neon-cyan)';
    }

    // Modal charts
    function initCharts() {
      // In real version, would fetch historical data
      drawLineChart('chart-token', [10,25,18,30,45,60,55,70,65,80,75,90], '#00ffff');
      drawLineChart('chart-session', [15,18,22,19,25,30,28,35,32,40,38,45], '#ff00ff');
      drawLineChart('chart-resource', [30,45,40,60,50,70,65,80,75,90,85,95], '#ffaa00');
    }

    function drawLineChart(canvasId, data, color) {
      const canvas = document.getElementById(canvasId);
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const w = canvas.width = canvas.offsetWidth;
      const h = canvas.height = canvas.offsetHeight;
      ctx.clearRect(0,0,w,h);
      ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.shadowColor = color; ctx.shadowBlur = 10;
      ctx.beginPath();
      const step = w / (data.length - 1);
      data.forEach((val, i) => {
        const x = i * step;
        const y = h - (val / 100) * h;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      });
      ctx.stroke();
      ctx.lineTo(w, h); ctx.lineTo(0, h);
      ctx.fillStyle = color.replace(')', ', 0.1)').replace('rgb', 'rgba');
      ctx.fill();
    }

    // Modal controls
    function openModal(agentKey) {
      const agent = agents[agentKey];
      document.getElementById('modal-title').textContent = `${agent.emoji} ${agent.name} DETAIL`;
      initCharts();
      addLog('UI', `Opened detail for ${agent.name}`);
      document.getElementById('agent-modal').classList.add('active');
    }

    
    // Heatmap
    function drawHeatmap(data) {
      const canvas = document.getElementById('heatmap');
      if (!canvas || !data || data.length === 0) return;
      const ctx = canvas.getContext('2d');
      const w = canvas.width = canvas.offsetWidth;
      const h = canvas.height = canvas.offsetHeight;
      ctx.clearRect(0,0,w,h);
      const cellW = w / 24;
      const maxVal = Math.max(...data, 1);
      data.forEach((val, i) => {
        const pct = Math.min(100, Math.round((val / maxVal) * 100));
        let r,g,b,a;
        if (pct < 50) { r=0; g=255; b=136; a = 0.4 + (pct/50)*0.4; }
        else if (pct < 80) { r=255; g=170; b=0; a = 0.4 + ((pct-50)/30)*0.4; }
        else { r=255; g=9; b=83; a = 0.4 + ((pct-80)/20)*0.4; }
        ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
        ctx.fillRect(i*cellW, 0, cellW-1, h);
      });
      ctx.fillStyle = 'var(--neon-cyan)';
      ctx.font = '10px JetBrains Mono';
      ctx.textAlign = 'center';
      for (let i = 0; i < 24; i++) {
        ctx.fillText(i+'h', i*cellW + cellW/2, h - 4);
      }
    }

    // Settings
    let ALERT_THRESHOLD = 80;
    let REFRESH_INTERVAL = 10;
    let SOUND_ENABLED = false;

    function openSettings() {
      document.getElementById('settings-modal').classList.add('active');
      document.getElementById('alert-threshold').value = ALERT_THRESHOLD;
      document.getElementById('refresh-interval').value = REFRESH_INTERVAL;
      document.getElementById('sound-alert').checked = SOUND_ENABLED;
    }

    function closeSettings() {
      document.getElementById('settings-modal').classList.remove('active');
    }

    function saveSettings() {
      ALERT_THRESHOLD = parseInt(document.getElementById('alert-threshold').value) || 80;
      REFRESH_INTERVAL = parseInt(document.getElementById('refresh-interval').value) || 10;
      SOUND_ENABLED = document.getElementById('sound-alert').checked;
      localStorage.setItem('dashboardSettings', JSON.stringify({ ALERT_THRESHOLD, REFRESH_INTERVAL, SOUND_ENABLED }));
      closeSettings();
      addLog('Settings', `Saved: threshold=${ALERT_THRESHOLD}, interval=${REFRESH_INTERVAL}s`);
      clearInterval(refreshTimer);
      refreshTimer = setInterval(fetchStatus, REFRESH_INTERVAL * 1000);
    }

    function loadSettings() {
      try {
        const saved = JSON.parse(localStorage.getItem('dashboardSettings') || '{}');
        if (saved.ALERT_THRESHOLD) ALERT_THRESHOLD = saved.ALERT_THRESHOLD;
        if (saved.REFRESH_INTERVAL) REFRESH_INTERVAL = saved.REFRESH_INTERVAL;
        if (saved.SOUND_ENABLED !== undefined) SOUND_ENABLED = saved.SOUND_ENABLED;
      } catch (e) {}
    }

function closeModal() {
      document.getElementById('agent-modal').classList.remove('active');
    }

    // Clock
    function updateClock() {
      const now = new Date();
      document.getElementById('clock').textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
      document.getElementById('date').textContent = now.toLocaleDateString('zh-CN');
    }

    // Init
    function init() {
      loadSettings();
      fetchStatus();
      updateClock();
      setInterval(updateClock, 1000);
      refreshTimer = setInterval(fetchStatus, REFRESH_INTERVAL * 1000);
      setInterval(fetchStatus, 10000);
      setInterval(drawTopology, 5000);
      drawTopology();
    }

    window.onload = init;
  </script>

  <!-- Settings Modal -->
  <div class="modal" id="settings-modal">
    <div class="modal-content" style="max-width:500px;">
      <div class="modal-close" onclick="closeSettings()">&times;</div>
      <div class="modal-header">
        <div class="modal-title">⚙️ SETTINGS</div>
        <button class="close-btn" onclick="closeSettings()">CLOSE</button>
      </div>
      <div class="modal-body" style="display:block;">
        <div class="setting-row">
          <label>
            <span>ALERT THRESHOLD (%)</span>
            <input type="number" id="alert-threshold" value="80" min="1" max="100">
          </label>
        </div>
        <div class="setting-row">
          <label>
            <span>REFRESH INTERVAL (s)</span>
            <input type="number" id="refresh-interval" value="10" min="3" max="60">
          </label>
        </div>
        <div class="setting-row">
          <label>
            <span>ENABLE SOUND ALERTS</span>
            <input type="checkbox" id="sound-alert">
          </label>
        </div>
        <button class="close-btn" onclick="saveSettings()" style="width:100%;margin-top:10px;">SAVE</button>
      </div>
    </div>
  </div>
</body>
</html>
